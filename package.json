{
  "name": "rae-noise-monorepo",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "license": "Apache-2.0",
  "author": "Raegan Grace Scheet",
  "homepage": "http://raedotzip.github.io/rae-noise/",
  "repository": {
    "type": "git",
    "url": "https://github.com/raedotzip/rae-noise"
  },
  "bugs": {
    "url": "https://github.com/raedotzip/rae-noise/issues"
  },
  "keywords": [
    "webgl",
    "opengl",
    "noise",
    "procedural",
    "shader",
    "graphics",
    "visuals",
    "background",
    "creative-coding",
    "generative-art",
    "typescript",
    "frontend"
  ],
  "sideEffects": false,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "build:docs": "turbo run build:docs",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "cs": "changeset",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "prepare": "husky",
    "build:affected": "turbo run build --filter=...[origin/main]",
    "test:affected": "turbo run test --filter=...[origin/main]",
    "graph:affected": "turbo run build --filter=...[origin/main] --graph"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@changesets/changelog-github": "^0.5.0",
    "@changesets/cli": "^2.27.0",
    "@playwright/test": "^1.59.1",
    "@vitest/coverage-v8": "^4.1.3",
    "concurrently": "^9.0.0",
    "happy-dom": "^20.8.9",
    "husky": "^9.1.7",
    "playwright": "^1.59.1",
    "turbo": "^2.9.6",
    "typedoc": "^0.28.18",
    "vitest": "^4.1.3"
  }
}
