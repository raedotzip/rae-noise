{
  "name": "rae-noise-monorepo",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "license": "Apache-2.0",
  "author": "Raegan Grace Scheet",
  "homepage": "http://raedotzip.github.io/rae-noise/",
  "repository": {
    "type": "git",
    "url": "https://github.com/raedotzip/rae-noise"
  },
  "bugs": {
    "url": "https://github.com/raedotzip/rae-noise/issues"
  },
  "keywords": [
    "webgl",
    "opengl",
    "noise",
    "procedural",
    "shader",
    "graphics",
    "visuals",
    "background",
    "creative-coding",
    "generative-art",
    "typescript",
    "frontend"
  ],
  "sideEffects": false,
  "scripts": {
    "dev": "concurrently \"pnpm dev:core\" \"pnpm dev:website\"",
    "dev:core": "pnpm --filter rae-noise watch",
    "dev:website": "pnpm --filter @rae-noise/website dev",
    "build": "pnpm build:core && pnpm build:website",
    "build:core": "pnpm --filter rae-noise build",
    "build:website": "pnpm --filter @rae-noise/website build",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "typecheck": "pnpm -r typecheck",
    "build:docs": "typedoc",
    "build:docs:json": "typedoc && echo 'JSON written to docs/api.json'",
    "cs": "changeset",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter @rae-noise/website test:e2e",
    "prepare": "husky",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@changesets/changelog-github": "^0.5.0",
    "@changesets/cli": "^2.27.0",
    "@playwright/test": "^1.59.1",
    "@vitest/coverage-v8": "^4.1.3",
    "concurrently": "^9.0.0",
    "happy-dom": "^20.8.9",
    "husky": "^9.1.7",
    "playwright": "^1.59.1",
    "typedoc": "^0.28.18",
    "vitest": "^4.1.3"
  }
}
