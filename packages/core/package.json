{
  "name": "rae-noise",
  "type": "module",
  "version": "1.0.0",
  "description": "Generate noise values for cool website visuals",
  "license": "Apache-2.0",
  "author": "Raegan Grace Scheet",
  "homepage": "http://raedotzip.github.io/rae-noise/",
  "repository": {
    "type": "git",
    "url": "https://github.com/raedotzip/rae-noise"
  },
  "bugs": {
    "url": "https://github.com/raedotzip/rae-noise/issues"
  },
  "keywords": [
    "webgl",
    "opengl",
    "noise",
    "procedural",
    "shader",
    "graphics",
    "visuals",
    "background",
    "creative-coding",
    "generative-art",
    "typescript",
    "frontend"
  ],
  "sideEffects": false,

  "main": "dist/cjs/index.cjs",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",

  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.cjs"
    }
  },

  "files": ["dist/"],

  "scripts": {
    "build": "rollup -c",
    "watch": "rollup -c -w",
    "prepublishOnly": "pnpm build",
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },

  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.0.0",
    "@types/node": "^25.5.2",
    "rollup": "^4.0.0",
    "rollup-plugin-glsl": "^1.3.0",
    "tslib": "^2.6.0",
    "typescript": "^5.0.0"
  }
}