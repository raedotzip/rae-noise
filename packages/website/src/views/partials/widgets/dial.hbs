<div class="group">
  <div class="group-label">
    direction
    {{> widgets/info-btn key="direction"}}
  </div>
  <div class="dir-row">
    <div class="dial">
      <div class="dial-needle"></div>
    </div>
    <div class="dir-values">
      dx <span class="accent" data-dir="dx">{{dx}}</span><br />
      dy <span class="accent" data-dir="dy">{{dy}}</span>
    </div>
  </div>
</div>
