<div class="group">
  <div class="toggle-row">
    <span class="group-label" style="margin:0">
      {{label}}
      {{> widgets/info-btn key=label}}
    </span>
    <label class="toggle">
      <input type="checkbox" {{#if checked}}checked{{/if}} />
      <div class="toggle-track"><div class="toggle-thumb"></div></div>
    </label>
  </div>
</div>
