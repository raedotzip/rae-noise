<div class="layer-body">
  {{> widgets/chip-group
      label="noise type"
      options=noiseTypes
      current=noiseType}}

  {{> widgets/chip-group
      label="blend mode"
      options=blendModes
      current=blendMode}}

  {{> widgets/toggle-row label="animate" checked=animate}}

  <div class="flow-group" style="display:{{#if animate}}block{{else}}none{{/if}}">
    {{> widgets/chip-group
        label="flow type"
        options=flowTypes
        current=flowType}}
  </div>

  {{> widgets/slider
      label="scale"
      min=0.1 max=12 step=0.1
      value=scale}}

  {{> widgets/slider
      label="speed"
      min=0 max=3 step=0.01
      value=speed}}

  <div class="dir-group{{#unless dirEnabled}} disabled{{/unless}}">
    {{> widgets/dial dx=dirDx dy=dirDy}}
  </div>

  <div class="octaves-group{{#unless fbmActive}} disabled{{/unless}}">
    {{> widgets/slider
        label="octaves"
        min=1 max=8 step=1
        value=octaves}}
  </div>

  {{> widgets/slider
      label="contrast"
      min=0.1 max=4 step=0.05
      value=contrast}}

  {{> widgets/slider
      label="brightness"
      min=-1 max=1 step=0.01
      value=brightness}}

  {{> widgets/slider
      label="domain warp"
      min=0 max=2 step=0.01
      value=warp}}

  {{> widgets/slider
      label="curl flow"
      min=0 max=2 step=0.01
      value=curlStrength}}

  {{> widgets/slider
      label="opacity"
      min=0 max=1 step=0.01
      value=opacity}}

  {{> widgets/palette-editor
      stops=paletteHex
      canRemove=paletteCanRemove
      maxReached=paletteMaxReached}}
</div>
