<div class="layer-card open" data-id="{{id}}">
  {{> layer/layer-header
      layerNum=layerNum
      name=name
      swatchGradient=swatchGradient}}
  {{> layer/layer-body
      noiseTypes=noiseTypes
      noiseType=noiseType
      blendModes=blendModes
      blendMode=blendMode
      flowTypes=flowTypes
      flowType=flowType
      animate=animate
      scale=scale
      speed=speed
      dirDx=dirDx
      dirDy=dirDy
      dirEnabled=dirEnabled
      octaves=octaves
      fbmActive=fbmActive
      contrast=contrast
      brightness=brightness
      warp=warp
      curlStrength=curlStrength
      opacity=opacity
      paletteHex=paletteHex
      paletteCanRemove=paletteCanRemove
      paletteMaxReached=paletteMaxReached}}
</div>
