{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",

  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        "dist/**",
        "packages/**/dist/**"
      ]
    },

    "test": {
      "dependsOn": ["build"],
      "outputs": []
    },

    "test:e2e": {
      "dependsOn": ["build"],
      "outputs": []
    },

    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },

    "lint": {
      "outputs": []
    },

    "build:docs": {
      "dependsOn": ["build"],
      "outputs": ["docs/**"]
    },

    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}